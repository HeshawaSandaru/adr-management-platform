NODE_ENV=development

# MongoDB
# MongoDB URI
# Docker: mongodb://mongo:27017/adr_db (mongo = docker service name)
# Local:  mongodb://localhost:27017/adr_db
MONGO_URI=mongodb://mongo:27017/adr_db

# Server
PORT=3000
API_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# App Info
APP_NAME=ADR Management Platform
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=debug