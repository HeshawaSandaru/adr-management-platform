NODE_ENV=development

# MongoDB
# Docker: mongodb://mongo:27017/adr_db (mongo = docker service name)
# Local:  mongodb://localhost:27017/adr_db
MONGO_URI=mongodb://localhost:27017/adr_db

# Server
PORT=3000

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=24h

# CORS - URL of the frontend dev server
FRONTEND_URL=http://localhost:5173
